# Copy to `.env` (gitignored) and fill in real keys. `run.sh` auto-sources it.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Langfuse pipeline visualization (Round 4 only). If LANGFUSE_PUBLIC_KEY
# is unset, the OpenTelemetry feature isn't installed and the demo runs as normal.
# Sign up at https://cloud.langfuse.com and grab the keys from Project Settings.
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
