%%{init: {'theme': 'base', 'themeVariables': {'background': '#fffaf0', 'primaryColor': '#fffaf0', 'primaryTextColor': '#1f2937', 'primaryBorderColor': '#8b7355', 'lineColor': '#6b5b3a'}}}%%
flowchart TD
    Start([User prompt]) --> Classify

    Classify["classify<br/>O3 Mini · reasoning"]
    Classify -- "intent = DECLINE_REQUEST" --> Identify
    Classify -- "intent = CHAT" --> ChatReply

    subgraph Pipeline [Decline pipeline]
        Identify["identifyDecline<br/>GPT-4o<br/>getCalendar, getEventAttendees"]
        Deploy["deployDecline<br/>Sonnet 4<br/>sendDecline"]
        Verify{"verifyDecline<br/>O3 · reasoning<br/>awaitReaction"}
        Refine["refineDecline<br/>Sonnet 4"]

        Identify --> Deploy
        Deploy --> Verify
        Verify -- "successful = true" --> DeclineSent([JclawResult.DeclineSent])
        Verify -- "successful = false" --> Refine
        Refine --> Verify
    end

    ChatReply["chatReply<br/>Sonnet 4.5<br/>UserTools only"]
    ChatReply --> ChatDone([JclawResult.ChatReply])

    classDef start fill:#e0f2fe,stroke:#0284c7,stroke-width:1.5px,color:#0c4a6e;
    classDef route fill:#fef3c7,stroke:#f59e0b,stroke-width:1.5px,color:#92400e;
    classDef terminal fill:#dcfce7,stroke:#16a34a,stroke-width:1.5px,color:#14532d;

    class Start start;
    class Classify route;
    class DeclineSent,ChatDone terminal;

    style Pipeline fill:#fafaf5,stroke:#9c8a5a,stroke-width:1px,color:#3f3f46;
